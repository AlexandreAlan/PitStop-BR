# APK gerado é publicado em src/downloads/, não versionado (binário grande)
src/downloads/*.apk

# Dependências PHP (Composer) — geradas por scripts/composer-install.sh
src/vendor/

# Cache de execução do PHPUnit (ver phpunit.xml)
.phpunit.cache/

# Relatórios de auditoria de segurança: ficam só no servidor — o repo é
# público, e listar vulnerabilidades específicas (mesmo já corrigidas) nele
# seria dar um roteiro de ataque de graça.
docs/auditoria-*.md
